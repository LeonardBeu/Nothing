function showSidebar(){SpreadsheetApp.getUi().showSidebar(HtmlService.createHtmlOutputFromFile('Sidebar').setTitle('Macro').setWidth(300));}
function getRibbonUI(){
  var s = safeGetSheet(SpreadsheetApp.getActiveSpreadsheet(), SHEET_SETTINGS);
  return {
    dc: s.getRange("Q2:Q20").getValues().flat().filter(String),
    sklad: s.getRange("R2:R50").getValues().flat().filter(String),
    defaults: {sapInput: s.getRange("G2").getValue(), evalInput: s.getRange("H2").getValue(), dateInput: s.getRange("I2").getValue()}
  };
}
function ribbonOnChange(id, v){
  var s = safeGetSheet(SpreadsheetApp.getActiveSpreadsheet(), SHEET_SETTINGS);
  if(id=="dc") s.getRange("A2").setValue(v);
  if(id=="sklad") s.getRange("B2").setValue(v);
  if(id=="sapInput") s.getRange("G2").setValue(v);
  if(id=="evalInput") s.getRange("H2").setValue(v);
  if(id=="dateInput") s.getRange("I2").setValue(v ? new Date(v) : "");
}
function ExportDat(){
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var lnk = safeGetSheet(ss, SHEET_SETTINGS).getRange("L2").getValue();
  var f = DriveApp.getFolderById(lnk.match(/[-\w]{25,}/)[0]);
  var nm = "Kritické_RLZ_" + Utilities.formatDate(new Date(), ss.getSpreadsheetTimeZone(), "yyyyMMdd");
  var nss = SpreadsheetApp.create(nm);
  safeGetSheet(ss, SHEET_FINAL).copyTo(nss).setName(SHEET_FINAL);
  safeGetSheet(ss, SHEET_ZEDMT_SAP).copyTo(nss).setName(SHEET_ZEDMT_SAP);
  nss.deleteSheet(nss.getSheets()[0]);
  DriveApp.getFileById(nss.getId()).moveTo(f);
  Browser.msgBox("Exported: " + nm);
}
function ExportFilialeDispo(){
  Logger.log("=== ExportFilialeDispo START ===");
  var ss = SpreadsheetApp.getActiveSpreadsheet();
  var sSettings = safeGetSheet(ss, SHEET_SETTINGS);
  var sExp = resetSheet(ss, SHEET_EXPORT_FIL);
  var sFin = safeGetSheet(ss, SHEET_FINAL);
  var sPro = safeGetSheet(ss, SHEET_PROCH_RLZ);
  
  // Get DC and Sklad from settings
  var dc = sSettings.getRange("A2").getValue();
  var sklad = sSettings.getRange("B2").getValue();
  var cesta = sSettings.getRange("L2").getValue();
  
  Logger.log("DC: " + dc + ", Sklad: " + sklad);
  
  // Set headers matching VBA exactly
  sExp.appendRow(["Záv.","Materiál","Krát.text materiálu","Množství k přerozdělení","VMJ","DMT","Kreis","Počet ks ve VMJ"]);
  
  var fD = sFin.getDataRange().getValues();
  var lstrow = fD.length;
  Logger.log("FinalData rows: " + lstrow);
  
  if(lstrow < 2) {
    Browser.msgBox("No data in FinálníData");
    return;
  }
  
  // Copy Material (C) and Text (D) columns from FinalData to Export B and C
  var materialTextData = [];
  for(var i=1; i<fD.length; i++){
    materialTextData.push([fD[i][2], fD[i][3]]);
  }
  if(materialTextData.length > 0) {
    ensureGridSize(sExp, materialTextData.length+1, 8);
    sExp.getRange(2, 2, materialTextData.length, 2).setValues(materialTextData);
  }
  
  Logger.log("Material and Text copied: " + materialTextData.length + " rows");
  
  // Get ProchazejiciRLZ data
  var pD = sPro.getDataRange().getValues();
  Logger.log("ProchazejiciRLZ size: " + pD.length + "x" + (pD.length > 0 ? pD[0].length : 0));
  
  if(pD.length < 2) {
    Logger.log("WARNING: ProchazejiciRLZ has no data rows");
  }
  
  var pHead = pD[0];
  var lstcol = pHead.length;
  Logger.log("ProchazejiciRLZ columns: " + lstcol);
  
  // Now process each row
  for(var row=2; row<=lstrow; row++){
    var rowIdx = row - 1; // Array index (row 2 = index 1)
    
    // Set columns 1, 4, 5, 7, 8 from FinalData
    sExp.getRange(row, 1).setValue(dc);
    sExp.getRange(row, 4).setValue(fD[rowIdx][12]); // Column M (index 12)
    sExp.getRange(row, 5).setValue(fD[rowIdx][32]); // Column AG (index 32)
    sExp.getRange(row, 7).setValue(fD[rowIdx][29]); // Column AD (index 29)
    sExp.getRange(row, 8).setValue(fD[rowIdx][25]); // Column Z (index 25)
    
    var prochZasoba = fD[rowIdx][12]; // Needed quantity
    var zasobaArtiklRLZ = 0;
    var dmtStr = "";
    
    // Get the article from the export sheet (already written in column B)
    var article = sExp.getRange(row, 2).getValue();
    
    if(!article) {
      Logger.log("Row " + row + ": No article found");
      continue;
    }
    
    // Find article in ProchazejiciRLZ
    var findArticleRow = -1;
    for(var p=1; p<pD.length; p++){
      if(pD[p][0] == article){
        findArticleRow = p;
        break;
      }
    }
    
    if(findArticleRow > -1){
      // Loop through columns (dates) starting from column 2 (index 1)
      for(var col=2; col<=lstcol; col++){
        var colIdx = col - 1;
        var cellVal = pD[findArticleRow][colIdx];
        
        // Check if cell is not empty (matching VBA logic)
        if(cellVal !== "" && cellVal != null && cellVal !== 0){
          var dateHeader = pHead[colIdx];
          var dateStr = "";
          
          if(dateHeader instanceof Date){
            dateStr = Utilities.formatDate(dateHeader, ss.getSpreadsheetTimeZone(), "dd.MM.yyyy");
          } else {
            dateStr = String(dateHeader);
          }
          
          if(dmtStr == ""){
            // First date
            dmtStr = dateStr;
            zasobaArtiklRLZ += Number(cellVal);
          } else {
            // Additional dates
            if(zasobaArtiklRLZ < prochZasoba){
              dmtStr += "; " + dateStr;
              zasobaArtiklRLZ += Number(cellVal);
            } else {
              // Stop accumulating, go to next article
              break;
            }
          }
        }
      }
    } else {
      Logger.log("Row " + row + ": Article '" + article + "' not found in ProchazejiciRLZ");
    }
    
    // Write DMT to column 6
    sExp.getRange(row, 6).setValue(dmtStr);
  }
  
  Logger.log("All rows processed");
  
  // Format and auto-resize
  sExp.getRange(2, 6, lstrow-1, 1).setNumberFormat("@"); // Text format for DMT
  sExp.autoResizeColumns(1, 8);
  
  // Export to Drive
  var folderId = (cesta.toString().match(/[-\w]{25,}/) || [cesta])[0];
  var folder = DriveApp.getFolderById(folderId);
  var myFileName = "Export_pro_Filiale_Dispo_" + 
    Utilities.formatDate(new Date(), ss.getSpreadsheetTimeZone(), "yyyyMMdd") + 
    "_" + dc + "_" + sklad;
  
  Logger.log("Creating export file: " + myFileName);
  
  // Create new spreadsheet
  var nss = SpreadsheetApp.create(myFileName);
  sExp.copyTo(nss).setName(SHEET_EXPORT_FIL);
  nss.deleteSheet(nss.getSheets()[0]);
  
  // Move to target folder
  DriveApp.getFileById(nss.getId()).moveTo(folder);
  
  Logger.log("=== ExportFilialeDispo END ===");
  Browser.msgBox("Export pro Filiale Dispo je připraven. Soubor je uložen na " + cesta);
}
