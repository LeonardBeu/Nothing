Sub ExportDat()
        
    cesta = [cesta]
    dc = [dc]
    sklad = [sklad]

    myFileName = "Kritické_RLZ_Frische_" & Format(Date, "yyyymmdd") & "_" & dc & "_" & sklad & ".xlsx"
    Worksheets(Array("FinálníData", "ZEDMT_SAP")).Copy
    
    With ActiveWorkbook
         .SaveAs Filename:=cesta & myFileName ', FileFormat:=xlWorkbookNormal
         .Close SaveChanges:=False
    End With
    
    MsgBox "Soubor je uložen na " & cesta, vbInformation

End Sub

