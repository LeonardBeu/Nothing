                .Cells(i, 25) = shtDispoReport.Cells(findArticleDispoReportRow, 16)
                .Cells(i, 27) = shtDispoReport.Cells(findArticleDispoReportRow, 36)
                .Cells(i, 28) = shtDispoReport.Cells(findArticleDispoReportRow, 37)
                .Cells(i, 29) = shtDispoReport.Cells(findArticleDispoReportRow, 18)
                .Cells(i, 30) = shtDispoReport.Cells(findArticleDispoReportRow, 17)
                .Cells(i, 33) = shtDispoReport.Cells(findArticleDispoReportRow, 7)
            End If
            
