                .Cells(i, 17) = shtDispoReport.Cells(findArticleDispoReportRow, 10)
                .Cells(i, 18) = shtDispoReport.Cells(findArticleDispoReportRow, 11)
                .Cells(i, 19) = shtDispoReport.Cells(findArticleDispoReportRow, 9)
                .Cells(i, 20) = shtDispoReport.Cells(findArticleDispoReportRow, 27)
                
                If shtDispoReport.Cells(findArticleDispoReportRow, 28) = 0 And shtDispoReport.Cells(findArticleDispoReportRow, 14) = "" Then
                    .Cells(i, 21) = ""
                    .Cells(i, 22) = ""
                Else
                    .Cells(i, 21) = shtDispoReport.Cells(findArticleDispoReportRow, 28)
                    .Cells(i, 22) = shtDispoReport.Cells(findArticleDispoReportRow, 14)
                End If
                
