Sub DohledaniAkce()
    With shtPromotion
        .Select
        .Range("AA1") = "Aktuální akce"
        .Range("AB1") = "Budoucí akce"
        
        lstrow = .Cells(Rows.Count, 1).End(xlUp).Row
        lstcol = .Cells(4, Columns.Count).End(xlToLeft).Column
        
        With shtPromotion.Sort
            With .SortFields
                .Clear
                .Add Key:=Range("D1:D" & lstrow), SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortTextAsNumbers
                .Add Key:=Range("Y1:Y" & lstrow), SortOn:=xlSortOnValues, Order:=xlAscending, DataOption:=xlSortNormal
            End With
            .SetRange Range("A2:Z" & lstrow)
            .Apply
        End With
        
        Row = 2
        
        Do
            If .Range("Y" & Row) <= Date Then
                .Range("AA" & Row) = .Range("A" & Row) & " | " & Format(.Range("Y" & Row), "dd.mm.yyyy")
                
                If .Range("D" & Row) = .Range("D" & Row + 1) Then
                    .Range("AB" & Row) = .Range("A" & Row + 1) & " | " & Format(.Range("Y" & Row + 1), "dd.mm.yyyy")
                End If
            Else
                .Range("AB" & Row) = .Range("A" & Row) & " | " & Format(.Range("Y" & Row), "dd.mm.yyyy")
                
                If .Range("D" & Row) = .Range("D" & Row + 1) Then
                    .Range("AB" & Row + 1) = .Range("A" & Row) & " | " & Format(.Range("Y" & Row), "dd.mm.yyyy")
                End If
            End If
                
            If .Range("D" & Row) = .Range("D" & Row - 1) Then
                .Range("AA" & Row) = .Range("AA" & Row - 1)
                .Range("AB" & Row) = .Range("AB" & Row - 1)
            End If
            
            Row = Row + 1
        Loop Until Row > lstrow
        
        .Columns("A:AB").AutoFit
        
    End With
End Sub

