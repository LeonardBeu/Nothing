Sub Vyhodnotit()

    Dim DMT_dle_procenta As Date
    Dim DMT_zasoba As Date

    With shtSettings
        .Select
        
        If .Range("A2").Value = "" Or Range("B2").Value = "" Then
            MsgBox "Není vyplnìno DC nebo sklad! Prosím zadej DC a sklad a spus znovu", vbCritical
            Exit Sub
        ElseIf .Range("G2").Value = "" Or .Range("H2").Value = "" Then
            MsgBox "Není vyplnìna zbývající doba platnosti pro SAP nebo pro vyhodnocení!", vbCritical
            Exit Sub
        ElseIf .Range("A2").Value = "9200" And .Range("B2").Value = "C33" Then
            MsgBox "Zadaný sklad " & .Range("B2").Value & " neodpovídá zvolenému DC " & .Range("A2").Value & "!", vbCritical
            Exit Sub
        ElseIf .Range("A2").Value = "9300" And .Range("B2").Value = "C23" Then
            MsgBox "Zadaný sklad " & .Range("B2").Value & " neodpovídá zvolenému DC " & .Range("A2").Value & "!", vbCritical
            Exit Sub
        ElseIf .Range("I2").Value = "" Then
            MsgBox "Není vyplnìno datum dodání pro hledání otevøených objednávek filiálek!", vbCritical
            Exit Sub
        ElseIf .Range("J2").Value = "" Then
            MsgBox "Není vyplnìn poèet dní pro vyhodnocení artiklù s krátkým RLZ!", vbCritical
            Exit Sub
        ElseIf .Range("K2").Value = "" Then
            MsgBox "Není vyplnìno procento pro vyhodnocení artiklù s krátkým RLZ!", vbCritical
            Exit Sub
        End If
    
    End With
    
    shtZEDMT.Visible = True
    shtDispoReport.Visible = True
    shtPivotZEDMT.Visible = True
    shtProchazejiciRLZ.Visible = True
    shtPromotion.Visible = True
    
    With shtFinalData
        .Select
        
        If .AutoFilterMode = True Then
            .AutoFilterMode = False
        End If
        
        lstrow = Cells(Rows.Count, 1).End(xlUp).Row
        lstcol = Cells(1, Columns.Count).End(xlToLeft).Column
        
        If lstrow > 1 Then
            .Range(Cells(2, 1), Cells(lstrow, lstcol)).Clear
        End If
    End With
    
    With shtDispoReport
        .Select
        .Cells.Clear
    End With
    
    With shtZEDMT
        .Select
        
        If .AutoFilterMode = True Then
            .AutoFilterMode = False
        End If
        
        .Cells.Clear
    End With
    
    Call ZEDMT_Query_SAP
    
    With shtZEDMT
        .Select
        
        .Columns("K").NumberFormat = "0"
        .Columns("M").NumberFormat = "0"
        .Columns("R").NumberFormat = "0"
        .Columns("V:W").NumberFormat = "m/d/yyyy"
        
        .Range("U1") = "Rozhodnutí"
        .Range("V1") = "Nejkratší DMT"
        .Range("W1") = "DMT"
        .Range("X1") = "kolli faktor"
        
        
        lstrow = Cells(Rows.Count, 1).End(xlUp).Row
        lstcol = Cells(1, Columns.Count).End(xlToLeft).Column
        
        .Range("W2").Select
        ActiveCell.FormulaR1C1 = "=DATEVALUE(CONCAT(RIGHT(RC[-13],2),""."",MID(RC[-13],5,2),""."",LEFT(RC[-13],4)))"
        .Range("X2").Select
        ActiveCell.FormulaR1C1 = "=RC[-13]/RC[-11]"
        
        If lstrow > 2 Then
            .Range("W2:X2").Select
            Selection.AutoFill Destination:=Range("W2:X" & lstrow), Type:=xlFillDefault
        End If
        
        For i = 2 To lstrow
        
            If .Range("P" & i) <= [DnyRLZ] Then
            
                DMT_dle_procenta = Date + WorksheetFunction.RoundDown(.Range("P" & i) * [ProcentoPrerozdeleni], 0)
                DMT_zasoba = Right(.Range("J" & i), 2) & "." & Mid(.Range("J" & i), 5, 2) & "." & Left(.Range("J" & i), 4)
                
                If DMT_zasoba <= DMT_dle_procenta Then
                    .Range("U" & i) = [PrerozdelitKratkeRLZ]
                Else
                    .Range("U" & i) = [Neprerozdelovat]
                End If
                
            Else
            
                If .Range("T" & i) <= [RLZ_zpracovani] Then
                    .Range("U" & i) = [PrerozdelitProchazejiciRLZ]
                Else
                    .Range("U" & i) = [Neprerozdelovat]
                End If
            
            End If
            
            .Range("V" & i) = Application.WorksheetFunction.MinIfs( _
            .Range("W1:W" & shtZEDMT.Cells(Rows.Count, 1).End(xlUp).Row), _
            .Range("E1:E" & shtZEDMT.Cells(Rows.Count, 1).End(xlUp).Row), .Range("E" & i))
                
        Next i
            
        .Range("$A$1:$X$" & lstrow).AutoFilter field:=lstcol - 3, Criteria1:="<>" & [Neprerozdelovat]
        lstrow = Cells(Rows.Count, 1).End(xlUp).Row
        
        If lstrow = 1 Then
            MsgBox "Žádný artikl nevyhodnocen, makro bude ukonèeno!", vbInformation
            GoTo konec
        Else
            .Range("E2:F" & lstrow).SpecialCells(xlCellTypeVisible).Copy
            shtFinalData.Range("C2").PasteSpecial xlPasteValues
        End If
    
    End With
    
    Call ZEDMT_zpracovani
    
    With shtFinalData
        .Select
        
        lstrow = Cells(Rows.Count, 3).End(xlUp).Row
        
        .Range("C1:D" & lstrow).RemoveDuplicates Columns:=Array(1, 2), Header:=xlYes
        
    End With
    
    Call Dispo_report_SAP
    
    With shtDispoReport
        .Select
        
        .Columns("U:Z").NumberFormat = "0.00"
        .Columns("AB").NumberFormat = "0.00"
        .Columns("AD").NumberFormat = "0.00"
        .Columns("AH:AK").NumberFormat = "0.00"
    End With
    
    Call Akce_Query_SAP
    Call DohledaniAkce
    
    With shtFinalData
        .Select
        
        lstrow = Cells(Rows.Count, 3).End(xlUp).Row
        
        For i = 2 To lstrow
    
        Set findArticleZEDMT = shtZEDMT.Range("E:E").Find(What:=.Range("C" & i).Value, LookAt:=xlWhole)
        Set findArticleDispoReport = shtDispoReport.Range("A:A").Find(What:=.Range("C" & i).Value, LookAt:=xlWhole)
        Set findArticleAkce = shtPromotion.Range("D:D").Find(What:=.Range("C" & i).Value, LookAt:=xlWhole)
        
            If findArticleZEDMT Is Nothing Then

            Else
                findArticleZEDMTRow = findArticleZEDMT.Row
                .Cells(i, 1) = shtZEDMT.Cells(findArticleZEDMTRow, 1)
                .Cells(i, 2) = shtZEDMT.Cells(findArticleZEDMTRow, 2)
                .Cells(i, 5) = Application.WorksheetFunction.SumIfs( _
                shtZEDMT.Range("M1:M" & shtZEDMT.Cells(Rows.Count, 1).End(xlUp).Row), _
                shtZEDMT.Range("E1:E" & shtZEDMT.Cells(Rows.Count, 1).End(xlUp).Row), .Range("C" & i), _
                shtZEDMT.Range("U1:U" & shtZEDMT.Cells(Rows.Count, 1).End(xlUp).Row), "<>" & [Neprerozdelovat])
                .Cells(i, 6) = shtZEDMT.Cells(findArticleZEDMTRow, 16)
                .Cells(i, 7) = shtZEDMT.Cells(findArticleZEDMTRow, 18)
                .Cells(i, 8) = shtZEDMT.Cells(findArticleZEDMTRow, 19)
                .Cells(i, 26) = shtZEDMT.Cells(findArticleZEDMTRow, 24)
                
                If shtZEDMT.Cells(findArticleZEDMTRow, 22) <= Date + 2 Then
                    .Range(.Cells(i, 1), .Cells(i, 33)).Interior.Color = RGB(255, 153, 0)
                End If
                
            End If
            
            If findArticleDispoReport Is Nothing Then
            
            Else
                findArticleDispoReportRow = findArticleDispoReport.Row
                .Cells(i, 9) = shtDispoReport.Cells(findArticleDispoReportRow, 22)
                .Cells(i, 10) = shtDispoReport.Cells(findArticleDispoReportRow, 23)
                .Cells(i, 11) = shtDispoReport.Cells(findArticleDispoReportRow, 24) + shtDispoReport.Cells(findArticleDispoReportRow, 25)
                .Cells(i, 12) = shtDispoReport.Cells(findArticleDispoReportRow, 26)
