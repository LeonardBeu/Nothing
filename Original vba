            For col = 2 To lstcol - 1
            
                Set findArticle = shtProchazejiciRLZ.Range("A:A").Find(What:=.Range("B" & Row).Value, LookAt:=xlWhole)
                
                If findArticle Is Nothing Then
                    
                Else
                    findArticleRow = findArticle.Row
                    
                    If shtProchazejiciRLZ.Cells(findArticleRow, col) <> "" Then
                        If .Cells(Row, 6) = "" Then
                            .Cells(Row, 6) = Format(shtProchazejiciRLZ.Cells(1, col), "dd.mm.yyyy")
